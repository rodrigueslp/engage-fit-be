APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_MAX_BODY_BYTES=1048576
IMPORT_MAX_UPLOAD_BYTES=10485760
LOGIN_RATE_LIMIT_REQUESTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
SETUP_RATE_LIMIT_REQUESTS=5
SETUP_RATE_LIMIT_WINDOW_SECONDS=3600
# CIDRs/IPs de proxies confiaveis separados por virgula. Vazio ignora X-Forwarded-For.
TRUSTED_PROXIES=
HTTP_READ_HEADER_TIMEOUT_SECONDS=5
HTTP_READ_TIMEOUT_SECONDS=30
HTTP_WRITE_TIMEOUT_SECONDS=300
HTTP_IDLE_TIMEOUT_SECONDS=120
HTTP_SHUTDOWN_TIMEOUT_SECONDS=20
DB_MAX_OPEN_CONNECTIONS=10
DB_MAX_IDLE_CONNECTIONS=5
DB_CONNECTION_MAX_LIFETIME_SECONDS=1800
DB_CONNECTION_MAX_IDLE_TIME_SECONDS=300
DATABASE_URL=postgres://boxengage:boxengage@localhost:5432/boxengage?sslmode=disable
JWT_SECRET=change-me
# Sessao do navegador. Em production, Secure e obrigatorio.
AUTH_COOKIE_NAME=engagefit_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_SESSION_MAX_AGE_SECONDS=86400
# Origens completas, separadas por virgula. Vazio e adequado para mesma origem.
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Capacidades do produto. Em production todas ficam desligadas por padrao e devem ser homologadas individualmente.
FEATURE_WHATSAPP_ENABLED=true
FEATURE_EMAIL_ENABLED=true
FEATURE_AUTOMATION_ENABLED=true
FEATURE_WORKOUTS_ENABLED=true
FEATURE_LLM_ENABLED=true
PLATFORM_ADMIN_NAME=Administrador EngageFit
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

# Onboarding inicial. Em production fica desabilitado por padrao.
# Se habilitado em production, use um token aleatorio com pelo menos 32 caracteres.
OWNER_SETUP_ENABLED=true
OWNER_SETUP_TOKEN=

# Conexao WhatsApp compartilhada, usada por padrao por novas academias.
# As credenciais ficam somente no ambiente do backend e nunca sao retornadas pela API.
WHATSAPP_PLATFORM_ENABLED=false
WHATSAPP_PLATFORM_BASE_URL=https://api.twilio.com
WHATSAPP_PLATFORM_TWILIO_SENDER=
WHATSAPP_PLATFORM_TWILIO_ACCOUNT_SID=
WHATSAPP_PLATFORM_TWILIO_AUTH_TOKEN=
WHATSAPP_PLATFORM_TWILIO_CONTENT_SID_ALMOST_THERE=
WHATSAPP_PLATFORM_TWILIO_CONTENT_SID_GOAL_REACHED=
WHATSAPP_PLATFORM_TWILIO_CONTENT_SID_WE_MISS_YOU=

# Envio real fica bloqueado em todos os ambientes ate habilitacao explicita.
WHATSAPP_ALLOW_REAL_SEND=false
WHATSAPP_DEV_RECIPIENT_PHONE=
WHATSAPP_DEV_ALLOWED_RECIPIENT_PHONES=

POSTGRES_DB=boxengage
POSTGRES_USER=boxengage
POSTGRES_PASSWORD=boxengage


# E-mail real fica bloqueado em todos os ambientes ate habilitacao explicita.
EMAIL_ALLOW_REAL_SEND=false
EMAIL_DEV_RECIPIENT_EMAIL=


# Worker interno que executa rotinas configuradas na tela Automacao.
AUTOMATION_WORKER_ENABLED=false
AUTOMATION_WORKER_INTERVAL_SECONDS=60
AUTOMATION_STALE_RUN_MINUTES=120
AUTOMATION_CATCHUP_WINDOW_MINUTES=15

# LLM usado para gerar rascunhos do Treino do dia.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30

# Observabilidade. Configure o endpoint OTLP HTTP do Collector local ou Grafana Cloud.
# O exporter usa tambem OTEL_EXPORTER_OTLP_HEADERS e os overrides por sinal da especificacao OTel.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=engagefit-api
OTEL_SERVICE_VERSION=dev
# Podem ser injetados por build args/ldflags; overrides de runtime sao opcionais.
BUILD_VERSION=
BUILD_COMMIT=
BUILD_TIME=
OTEL_TRACE_SAMPLE_RATIO=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=

# Em production, se habilitado, exige token Bearer aleatorio com ao menos 32 caracteres.
PROMETHEUS_ENABLED=true
PROMETHEUS_BEARER_TOKEN=

# Criptografia AES-256-GCM de credenciais persistidas. Cada chave e base64 de 32 bytes.
# Mantenha chaves antigas no keyring durante a rotacao e nunca reutilize estes exemplos.
DATA_ENCRYPTION_ACTIVE_KEY_ID=
DATA_ENCRYPTION_KEYS=

# Billing / Asaas
FEATURE_BILLING_ENABLED=false
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_TIMEOUT_SECONDS=15

# Retencao em dias. O comando apenas simula sem --apply.
PRIVACY_RETENTION_COMMUNICATION_DAYS=365
PRIVACY_RETENTION_LLM_LOG_DAYS=90
PRIVACY_RETENTION_AUTOMATION_RUN_DAYS=180
PRIVACY_RETENTION_CHECKIN_DAYS=730
PRIVACY_RETENTION_AUDIT_DAYS=1825
PRIVACY_RETENTION_BILLING_WEBHOOK_DAYS=365
