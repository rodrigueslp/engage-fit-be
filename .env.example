APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
DATABASE_URL=postgres://boxengage:boxengage@localhost:5432/boxengage?sslmode=disable
JWT_SECRET=change-me

POSTGRES_DB=boxengage
POSTGRES_USER=boxengage
POSTGRES_PASSWORD=boxengage


# E-mail real fica bloqueado em development por padrao.
EMAIL_ALLOW_REAL_SEND=false
EMAIL_DEV_RECIPIENT_EMAIL=


# Worker interno que executa rotinas configuradas na tela Automacao.
AUTOMATION_WORKER_ENABLED=false
AUTOMATION_WORKER_INTERVAL_SECONDS=60

# LLM usado para gerar rascunhos do Treino do dia.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
